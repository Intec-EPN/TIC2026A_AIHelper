{{!
    Vista General del profesor: Actividades - Detalle VPL - Detalle Estudiante.

}}
<div class="slm-report-wrapper">

    {{! PESTANAS PRINCIPALES }}
    <ul class="nav nav-tabs mb-0" role="tablist">
        <li class="nav-item" role="none">
            <a class="nav-link {{#active_general}}active{{/active_general}}" href="{{nav_general_url}}">{{str_nav_general}}</a>
        </li>
        <li class="nav-item" role="none">
            <a class="nav-link {{#active_catalog}}active{{/active_catalog}}" href="{{nav_catalog_url}}">{{str_nav_catalog}}</a>
        </li>
        <li class="nav-item" role="none">
            <a class="nav-link {{#active_config}}active{{/active_config}}" href="{{nav_config_url}}">{{str_nav_config}}</a>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-3 bg-white">

        {{! vistas principales}}
        {{#show_activities}}
        <div class="d-flex mb-3">
            <div class="navitem">
                <nav class="tertiary-navigation-selector">
                    <div class="dropdown select-menu">
                        <div class="btn btn-outline-secondary dropdown-toggle"
                             role="combobox" data-bs-toggle="dropdown"
                             aria-haspopup="listbox" aria-expanded="false" tabindex="0">
                            {{subview_label}}
                        </div>
                        <ul class="dropdown-menu" role="listbox">
                            <li role="none">
                                <ul role="group" class="list-unstyled mb-0">
                                    <li class="dropdown-item {{#subview_activities_active}}active{{/subview_activities_active}}"
                                        role="option" data-value="{{url_activities}}" style="cursor:pointer;">
                                        {{str_subview_activities}}
                                    </li>
                                    <li class="dropdown-item {{#subview_concepts_active}}active{{/subview_concepts_active}}"
                                        role="option" data-value="{{url_concepts}}" style="cursor:pointer;">
                                        {{str_subview_concepts}}
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
        </div>
        {{/show_activities}}
        {{#show_concepts}}
        <div class="d-flex mb-3">
            <div class="navitem">
                <nav class="tertiary-navigation-selector">
                    <div class="dropdown select-menu">
                        <div class="btn btn-outline-secondary dropdown-toggle"
                             role="combobox" data-bs-toggle="dropdown"
                             aria-haspopup="listbox" aria-expanded="false" tabindex="0">
                            {{subview_label}}
                        </div>
                        <ul class="dropdown-menu" role="listbox">
                            <li role="none">
                                <ul role="group" class="list-unstyled mb-0">
                                    <li class="dropdown-item {{#subview_activities_active}}active{{/subview_activities_active}}"
                                        role="option" data-value="{{url_activities}}" style="cursor:pointer;">
                                        {{str_subview_activities}}
                                    </li>
                                    <li class="dropdown-item {{#subview_concepts_active}}active{{/subview_concepts_active}}"
                                        role="option" data-value="{{url_concepts}}" style="cursor:pointer;">
                                        {{str_subview_concepts}}
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
        </div>
        {{/show_concepts}}

        {{!  TABLA DE ACTIVIDADES }}
        {{#show_activities}}
        {{#has_activities}}
        <div class="table-responsive">
            <table class="table table-hover align-middle slm-general-table">
                <thead class="table-light">
                    <tr>
                        <th class="slm-col-activity">{{str_col_activity}}</th>
                        <th class="text-center slm-col-sm">{{str_col_students}}</th>
                        <th class="slm-col-md">{{str_col_errors}}</th>
                        <th class="slm-col-md">{{str_col_concepts}}</th>
                        <th class="slm-col-md">{{str_col_resources}}</th>
                        <th class="slm-col-md">{{str_col_examples}}</th>
                        <th class="text-center slm-col-sm">{{str_col_detail}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#activities}}
                    <tr>
                        {{! Nombre de la actividad }}
                        <td>
                            <a href="{{url}}" target="_blank" class="fw-semibold text-decoration-none text-dark">
                                <i class="fa fa-code fa-fw text-secondary me-1"></i>{{name}}
                            </a>
                        </td>
                        {{! Cantidad de estudiantes }}
                        <td class="text-center">
                            {{#has_data}}
                            <span class="badge bg-primary rounded-pill">{{student_count}}</span>
                            {{/has_data}}
                            {{^has_data}}
                            <span class="text-muted small">—</span>
                            {{/has_data}}
                        </td>
                        {{! Errores frecuentes }}
                        <td>
                            {{#top_errors}}
                            <div class="slm-tag slm-tag-error mb-1">
                                {{! <i class="fa fa-bug fa-fw"></i> }}
                                {{titulo}}
                            </div>
                            {{/top_errors}}
                            {{^top_errors}}<span class="text-muted small">—</span>{{/top_errors}}
                        </td>
                        {{! Conceptos del profesor }}
                        <td>
                            {{#top_concepts}}
                            <div class="slm-tag slm-tag-concept mb-1">
                                {{! <i class="fa fa-lightbulb fa-fw"></i> }}
                                {{nombre}}
                            </div>
                            {{/top_concepts}}
                            {{^top_concepts}}<span class="text-muted small">—</span>{{/top_concepts}}
                        </td>
                        {{! Recursos del profesor }}
                        <td>
                            {{#top_resources}}
                            <div class="slm-tag slm-tag-resource mb-1">
                                {{! <i class="fa fa-book fa-fw"></i> }}
                                {{titulo}}
                            </div>
                            {{/top_resources}}
                            {{^top_resources}}<span class="text-muted small">—</span>{{/top_resources}}
                        </td>
                        {{! Ejemplos IA }}
                        <td>
                            {{#top_examples}}
                            <div class="slm-tag slm-tag-ia mb-1">
                                {{! <i class="fa fa-robot fa-fw"></i> }}
                                {{titulo}}
                            </div>
                            {{/top_examples}}
                            {{^top_examples}}<span class="text-muted small">—</span>{{/top_examples}}
                        </td>
                        {{! Ver detalle }}
                        <td class="text-center">
                            <a href="{{detail_url}}" class="btn btn-sm btn-outline-primary">
                                {{str_view_detail}} <i class="fa fa-arrow-right fa-fw"></i>
                            </a>
                        </td>
                    </tr>
                    {{/activities}}
                </tbody>
            </table>
        </div>
        {{/has_activities}}
        {{^has_activities}}
        <div class="alert alert-info mt-3">{{str_no_activities}}</div>
        {{/has_activities}}
        {{/show_activities}}

        {{! DETALLE DE ACTIVIDAD VPL -> lista de estudiantes }}
        {{#show_vpl_detail}}
        {{! Breadcrumb }}
        <nav class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a href="{{back_url}}">{{str_back}}</a>
                </li>
                <li class="breadcrumb-item active">{{#vpl}}{{name}}{{/vpl}}</li>
            </ol>
        </nav>

        {{#vpl}}
        <div class="d-flex align-items-center gap-2 mb-4">
            <i class="fa fa-code fa-fw text-secondary"></i>
            <h5 class="mb-0 fw-semibold">{{name}}</h5>
            <a href="{{url}}" target="_blank" class="btn btn-sm btn-outline-secondary ms-2">
                <i class="fa fa-external-link fa-fw"></i>
            </a>
        </div>
        {{/vpl}}

        {{#has_students}}
        <div class="table-responsive">
            <table class="table table-hover align-middle slm-general-table">
                <thead class="table-light">
                    <tr>
                        <th class="slm-col-activity">{{str_col_student}}</th>
                        <th class="text-center slm-col-sm">{{str_col_requests}}</th>
                        <th class="slm-col-sm">{{str_col_last}}</th>
                        <th class="slm-col-md">{{str_col_errors}}</th>
                        <th class="slm-col-md">{{str_col_concepts}}</th>
                        <th class="slm-col-md">{{str_col_resources}}</th>
                        <th class="slm-col-md">{{str_col_examples}}</th>
                        <th class="text-center slm-col-sm">{{str_col_detail}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#students}}
                    <tr>
                        <td class="fw-semibold">
                            <i class="fa fa-user-circle fa-fw text-secondary me-1"></i>{{fullname}}
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">{{solicitud_count}}</span>
                        </td>
                        <td class="text-muted small">{{last_request}}</td>
                        <td>
                            {{#top_errors}}
                            <div class="slm-tag slm-tag-error mb-1">
                                {{! <i class="fa fa-bug fa-fw"></i> }}
                                {{titulo}}
                            </div>
                            {{/top_errors}}
                            {{^top_errors}}<span class="text-muted small">—</span>{{/top_errors}}
                        </td>
                        <td>
                            {{#top_concepts}}
                            <div class="slm-tag slm-tag-concept mb-1">
                                {{! <i class="fa fa-lightbulb fa-fw"></i> }}
                                {{nombre}}
                            </div>
                            {{/top_concepts}}
                            {{^top_concepts}}<span class="text-muted small">—</span>{{/top_concepts}}
                        </td>
                        <td>
                            {{#top_resources}}
                            <div class="slm-tag slm-tag-resource mb-1">
                                {{! <i class="fa fa-book fa-fw"></i> }}
                                {{titulo}}
                            </div>
                            {{/top_resources}}
                            {{^top_resources}}<span class="text-muted small">—</span>{{/top_resources}}
                        </td>
                        <td>
                            {{#top_examples}}
                            <div class="slm-tag slm-tag-ia mb-1">
                                {{! <i class="fa fa-robot fa-fw"></i> }}
                                {{titulo}}
                            </div>
                            {{/top_examples}}
                            {{^top_examples}}<span class="text-muted small">—</span>{{/top_examples}}
                        </td>
                        <td class="text-center">
                            <a href="{{detail_url}}" class="btn btn-sm btn-outline-primary">
                                {{str_view_detail}} <i class="fa fa-arrow-right fa-fw"></i>
                            </a>
                        </td>
                    </tr>
                    {{/students}}
                </tbody>
            </table>
        </div>
        {{/has_students}}
        {{^has_students}}
        <div class="alert alert-info">{{str_no_students}}</div>
        {{/has_students}}
        {{/show_vpl_detail}}

        {{! SUBVISTA: DETALLE DE ESTUDIANTE -> historial de solicitudes }}
        {{#show_student_detail}}

        {{! Breadcrumb }}
        <nav class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="{{back_url}}">{{str_back}}</a></li>
                <li class="breadcrumb-item active">{{#student}}{{fullname}}{{/student}}</li>
            </ol>
        </nav>

        {{! Cabecera con nombre del VPL, estudiante y botn de modo edición }}
        <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
            {{#vpl}}
            <div class="d-flex align-items-center gap-2">
                <i class="fa fa-code fa-fw text-secondary"></i>
                <span class="fw-semibold">{{name}}</span>
            </div>
            {{/vpl}}
            <div class="vr"></div>
            {{#student}}
            <div class="d-flex align-items-center gap-2">
                <i class="fa fa-user-circle fa-fw text-secondary"></i>
                <span class="fw-semibold">{{fullname}}</span>
            </div>
            {{/student}}
            <div class="ms-auto">
                <button type="button" id="slm-edit-mode-btn" class="btn btn-sm btn-outline-secondary">
                    <i class="fa fa-pencil fa-fw"></i> Modo edición
                </button>
            </div>
        </div>

        {{! Historial de solicitudes }}
        {{#has_history}}
        <div class="d-flex flex-column gap-3">
            {{#history}}
            <div class="card border slm-history-card">
                <div class="card-header bg-light py-2" style="cursor:pointer;"
                     data-bs-toggle="collapse" data-bs-target="#slm-history-{{numero}}">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa fa-chevron-down fa-fw small text-muted"></i>
                        <span class="badge bg-secondary">Solicitud #{{numero}}</span>
                        <span class="text-muted small">{{fecha}}</span>
                    </div>
                </div>
                <div class="collapse show" id="slm-history-{{numero}}">
                    <div class="card-body p-0">
                        {{#has_errors}}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 slm-detail-table">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:18%;">Título</th>
                                        <th style="width:22%;">Descripción</th>
                                        <th style="width:22%;">Recomendación</th>
                                        <th style="width:24%;">Conceptos y recursos</th>
                                        <th style="width:14%;">Ejemplos IA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#errors_enriched}}
                                    <tr>
                                        {{!  TÍTULO  }}
                                        <td>
                                            <div class="slm-fw" data-errorid="{{errorid}}" data-field="titulo">
                                                <span class="slm-fv fw-semibold small">{{titulo}}</span>
                                                <button type="button" class="slm-pencil-btn" style="display:none;" title="Editar título">
                                                    <i class="fa fa-pencil" style="font-size:10px;color:#adb5bd;"></i>
                                                </button>
                                                <div class="slm-field-editor" style="display:none;width:100%;">
                                                    <textarea class="form-control form-control-sm" rows="2" style="font-size:12px;background:#fffde7;border:1px solid #f9a825;"></textarea>
                                                    <div style="display:flex;gap:4px;margin-top:4px;">
                                                        <button type="button" class="slm-fsave btn btn-sm btn-primary" style="font-size:11px;padding:2px 8px;"><i class="fa fa-check fa-fw"></i> Guardar</button>
                                                        <button type="button" class="slm-fcancel btn btn-sm btn-outline-secondary" style="font-size:11px;padding:2px 8px;">Cancelar</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        {{!  DESCRIPCIoN  }}
                                        <td>
                                            <div class="slm-fw" data-errorid="{{errorid}}" data-field="descripcion_error">
                                                <span class="slm-fv small text-muted">{{descripcion_error}}</span>
                                                <button type="button" class="slm-pencil-btn" style="display:none;" title="Editar descripción">
                                                    <i class="fa fa-pencil" style="font-size:10px;color:#adb5bd;"></i>
                                                </button>
                                                <div class="slm-field-editor" style="display:none;width:100%;">
                                                    <textarea class="form-control form-control-sm" rows="3" style="font-size:12px;background:#fffde7;border:1px solid #f9a825;"></textarea>
                                                    <div style="display:flex;gap:4px;margin-top:4px;">
                                                        <button type="button" class="slm-fsave btn btn-sm btn-primary" style="font-size:11px;padding:2px 8px;"><i class="fa fa-check fa-fw"></i> Guardar</button>
                                                        <button type="button" class="slm-fcancel btn btn-sm btn-outline-secondary" style="font-size:11px;padding:2px 8px;">Cancelar</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        {{!  RECOMENDACION  }}
                                        <td>
                                            <div class="slm-fw" data-errorid="{{errorid}}" data-field="recomendacion">
                                                <span class="slm-fv small">{{recomendacion}}</span>
                                                <button type="button" class="slm-pencil-btn" style="display:none;" title="Editar recomendación">
                                                    <i class="fa fa-pencil" style="font-size:10px;color:#adb5bd;"></i>
                                                </button>
                                                <div class="slm-field-editor" style="display:none;width:100%;">
                                                    <textarea class="form-control form-control-sm" rows="3" style="font-size:12px;background:#fffde7;border:1px solid #f9a825;"></textarea>
                                                    <div style="display:flex;gap:4px;margin-top:4px;">
                                                        <button type="button" class="slm-fsave btn btn-sm btn-primary" style="font-size:11px;padding:2px 8px;"><i class="fa fa-check fa-fw"></i> Guardar</button>
                                                        <button type="button" class="slm-fcancel btn btn-sm btn-outline-secondary" style="font-size:11px;padding:2px 8px;">Cancelar</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        {{!  CONCEPTOS Y RECURSOS  }}
                                        <td>
                                            {{#has_concepts}}
                                            {{#concepts}}
                                            <div class="mb-2">
                                                <span class="slm-tag slm-tag-concept">{{nombre}}</span>
                                                {{#has_resources}}
                                                <div class="slm-resource-list mt-1">
                                                    {{#resources}}
                                                    {{#has_url}}
                                                    <a href="{{url}}" target="_blank" class="slm-resource-link d-block">
                                                        <i class="fa fa-link fa-fw"></i>{{titulo}}
                                                    </a>
                                                    {{/has_url}}
                                                    {{^has_url}}
                                                    <span class="slm-resource-link d-block">
                                                        <i class="fa fa-file fa-fw"></i>{{titulo}}
                                                    </span>
                                                    {{/has_url}}
                                                    {{/resources}}
                                                </div>
                                                {{/has_resources}}
                                            </div>
                                            {{/concepts}}
                                            {{/has_concepts}}
                                            {{^has_concepts}}<span class="text-muted small">—</span>{{/has_concepts}}
                                        </td>
                                        {{!  EJEMPLOS IA  }}
                                        <td>
                                            {{#has_examples}}
                                            {{#examples}}
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary slm-example-btn d-block mb-1 text-start w-100"
                                                    data-ejemploid="{{ejemploid}}">
                                                <i class="fa fa-robot fa-fw text-muted"></i>
                                                <span class="small">{{titulo}}</span>
                                            </button>
                                            {{! Datos ocultos para el modal }}
                                            <div class="d-none slm-example-data" data-ejemploid="{{ejemploid}}">
                                                <div data-field="titulo">{{titulo}}</div>
                                                <div data-field="descripcion">{{{descripcion_ejemplo}}}</div>
                                                <div data-field="codigo">{{{codigo}}}</div>
                                                <div data-field="explicacion">{{{explicacion}}}</div>
                                                <div data-field="resultado">{{{resultado_esperado}}}</div>
                                                <div data-field="has_codigo">{{has_codigo}}</div>
                                                <div data-field="has_resultado">{{has_resultado}}</div>
                                            </div>
                                            {{/examples}}
                                            {{/has_examples}}
                                            {{^has_examples}}<span class="text-muted small">—</span>{{/has_examples}}
                                        </td>
                                    </tr>
                                    {{/errors_enriched}}
                                </tbody>
                            </table>
                        </div>
                        {{/has_errors}}
                        {{^has_errors}}<div class="p-3 text-muted small">Sin errores registrados.</div>{{/has_errors}}
                    </div>
                </div>
            </div>
            {{/history}}
        </div>
        {{/has_history}}
        {{^has_history}}<div class="alert alert-info">{{str_no_history}}</div>{{/has_history}}

        {{!  Modal de ejemplo IA  }}
        <div class="modal fade" id="slm-example-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="fa fa-robot fa-fw text-muted me-2"></i>
                            <span id="slm-modal-titulo"></span>
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" id="slm-modal-body">
                        {{! JS los reemplaza con textareas en modo edición }}
                        <div class="mb-3">
                            <div class="small fw-semibold text-muted mb-1">Descripción</div>
                            <div id="slm-modal-descripcion" class="small text-muted"></div>
                        </div>
                        <div id="slm-modal-codigo-wrap" class="mb-3">
                            <div class="small fw-semibold mb-1">Código de ejemplo</div>
                            <pre class="slm-code-block"><code id="slm-modal-codigo"></code></pre>
                        </div>
                        <div class="mb-3">
                            <div class="small fw-semibold mb-1">Explicación</div>
                            <div id="slm-modal-explicacion" class="small"></div>
                        </div>
                        <div id="slm-modal-resultado-wrap" class="alert alert-light border">
                            <div class="small fw-semibold mb-1">Resultado esperado</div>
                            <div id="slm-modal-resultado" class="small"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="slm-modal-save-btn" class="btn btn-sm btn-primary" style="display:none;">
                            <i class="fa fa-save fa-fw"></i> Guardar ejemplo
                        </button>
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>

        {{/show_student_detail}}

        {{! SUBVISTA: CONCEPTOS }}
        {{#show_concepts}}
        {{^has_temas}}
        <div class="alert alert-warning d-flex gap-3 align-items-start mt-2">
            <i class="fa fa-triangle-exclamation fa-lg mt-1"></i>
            <div>
                <strong>{{str_concepts_no_catalog}}</strong>
                <p class="mb-1 mt-1">{{str_concepts_no_catalog_body}}</p>
                <a href="{{url_catalog}}" class="btn btn-sm btn-outline-warning">{{str_concepts_go_catalog}}</a>
            </div>
        </div>
        {{/has_temas}}
        {{#has_temas}}
        {{#temas}}
        <div class="card mb-4">
            <div class="card-header bg-light d-flex align-items-center gap-2 py-2">
                <button type="button" class="btn btn-sm btn-link p-0 text-dark"
                        data-bs-toggle="collapse" data-bs-target="#slm-tema-{{temaid}}">
                    <i class="fa fa-chevron-down fa-fw"></i>
                </button>
                <strong>{{nombre}}</strong>
                <span class="badge bg-secondary ms-auto">{{count}} concepto{{#count_plural}}s{{/count_plural}}</span>
            </div>
            <div class="collapse show" id="slm-tema-{{temaid}}">
                <div class="table-responsive">
                    <table class="table table-hover align-middle slm-general-table mb-0">
                        <thead class="table-light" style="border-top: none;">
                            <tr>
                                <th style="width:20%;">{{str_col_concept}}</th>
                                <th class="text-center" style="width:8%;">{{str_col_occurrences}}</th>
                                <th style="width:30%;">{{str_col_errors}}</th>
                                <th style="width:30%;">{{str_col_resources}}</th>
                                <th class="text-center" style="width:12%;">{{str_col_detail}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#conceptos}}
                            <tr>
                                <td>
                                    <span class="slm-tag slm-tag-concept">
                                        {{! <i class="fa fa-lightbulb fa-fw"></i> }} {{nombre}}
                                    </span>
                                </td>
                                <td class="text-center">
                                    {{#has_data}}<span class="badge bg-primary rounded-pill">{{occurrences}}</span>{{/has_data}}
                                    {{^has_data}}<span class="text-muted small">0</span>{{/has_data}}
                                </td>
                                <td>
                                    {{#has_errors}}
                                    {{#top_errors}}
                                    <div class="slm-tag slm-tag-error mb-1">
                                        {{! <i class="fa fa-bug fa-fw"></i> }} {{titulo}}
