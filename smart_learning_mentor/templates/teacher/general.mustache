{{! Este Scripts JS toca colocar de manera correcta segun la estructura definida, por temas de tiempo se coloca de manera temporal }}

<script>
(function() {

    // ----- Dropdown navegación -----------------------------------------------
    document.querySelectorAll('.slm-report-wrapper .select-menu [role="option"]').forEach(function(item) {
        item.addEventListener('click', function() {
            var url = this.getAttribute('data-value');
            if (url) { window.location.href = url; }
        });
    });

    // --- Variables -----------------------------------------------
    var editActive  = false;
    var currentEjId = null;
    var courseId    = parseInt(new URLSearchParams(window.location.search).get('courseid') || '0', 10);

    // --- AJAX -----------------------------------------------
    function saveViaAjax(tipo, id, campos, onDone) {
        console.log('slm save:', tipo, id, campos, 'courseid:', courseId);
        require(['core/ajax'], function(Ajax) {
            Ajax.call([{
                methodname: 'local_smart_learning_mentor_save_teacher_edit',
                args: { tipo: tipo, id: id, courseid: courseId, campos: campos },
            }])[0].then(function(res) {
                console.log('slm save response:', res);
                if (onDone) { onDone(res.success); }
            }).catch(function(err) {
                console.error('slm save_teacher_edit ERROR:', err);
                if (onDone) { onDone(false); }
            });
        });
    }

    // -- Modo edicin-- mostrar/ocultar lapices -----------------------------------------------
    var editBtn = document.getElementById('slm-edit-mode-btn');
    if (editBtn) {
        editBtn.addEventListener('click', function() {
            editActive = !editActive;
            editBtn.classList.toggle('btn-outline-secondary', !editActive);
            editBtn.classList.toggle('btn-warning', editActive);
            editBtn.innerHTML = editActive
                ? '<i class="fa fa-times fa-fw"></i> Salir de edición'
                : '<i class="fa fa-pencil fa-fw"></i> Modo edición';

            // Mostrar u ocultar TODOS los lápices de la tabla.
            document.querySelectorAll('.slm-pencil-btn').forEach(function(btn) {
                btn.style.display = editActive ? 'inline-block' : 'none';
            });

            // Si salimos de edición, cerrar cualquier editor abierto sin guardar.
            if (!editActive) {
                document.querySelectorAll('.slm-field-editor').forEach(function(ed) {
                    if (ed.style.display !== 'none') {
                        var fw  = ed.closest('.slm-fw');
                        var fv  = fw ? fw.querySelector('.slm-fv') : null;
                        if (fv)  { fv.style.display  = ''; }
                        ed.style.display = 'none';
                    }
                });
            }
        });

        // ----- Lapiz: abrir editor de campo -----------------------------------------------
        document.addEventListener('click', function(e) {
            var pencil = e.target.closest('.slm-pencil-btn');
            if (!pencil || !editActive) { return; }
            var fw     = pencil.closest('.slm-fw');
            var fv     = fw.querySelector('.slm-fv');
            var editor = fw.querySelector('.slm-field-editor');
            var ta     = editor.querySelector('textarea');

            // Cargar valor actual en el textarea.
            ta.value = fv ? fv.textContent.trim() : '';

            // Mostrar editor, ocultar texto y lápiz.
            fv.style.display     = 'none';
            pencil.style.display = 'none';
            editor.style.display = 'block';
            ta.focus();
        });

        // ----- Guardar campo -----------------------------------------------
        document.addEventListener('click', function(e) {
            var saveBtn = e.target.closest('.slm-fsave');
            if (!saveBtn) { return; }
            var editor  = saveBtn.closest('.slm-field-editor');
            var fw      = editor.closest('.slm-fw');
            var fv      = fw.querySelector('.slm-fv');
            var ta      = editor.querySelector('textarea');
            var errorid = parseInt(fw.dataset.errorid, 10);
            var field   = fw.dataset.field;
            var newval  = ta.value.trim();
            var campos  = {};
            campos[field] = newval;

            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="fa fa-spinner fa-spin fa-fw"></i>';

            saveViaAjax('error', errorid, campos, function(ok) {
                saveBtn.disabled = false;
                if (ok) {
                    if (fv) { fv.textContent = newval; }
                    // Restaurar: ocultar editor, mostrar texto y lápiz.
                    editor.style.display = 'none';
                    fv.style.display     = '';
                    var pencil = fw.querySelector('.slm-pencil-btn');
                    if (pencil) { pencil.style.display = editActive ? 'inline-block' : 'none'; }
                    saveBtn.innerHTML = '<i class="fa fa-check fa-fw"></i> Guardar';
                } else {
                    saveBtn.innerHTML = '<i class="fa fa-save fa-fw"></i> Reintentar';
                }
            });
        });

        // ----- Cancelar campo -----------------------------------------------
        document.addEventListener('click', function(e) {
            var cancelBtn = e.target.closest('.slm-fcancel');
            if (!cancelBtn) { return; }
            var editor = cancelBtn.closest('.slm-field-editor');
            var fw     = editor.closest('.slm-fw');
            var fv     = fw.querySelector('.slm-fv');
            var pencil = fw.querySelector('.slm-pencil-btn');
            editor.style.display = 'none';
            fv.style.display     = '';
            if (pencil) { pencil.style.display = editActive ? 'inline-block' : 'none'; }
        });
    }

    // ----- Modal de ejemplo IA -----------------------------------------------
    document.querySelectorAll('.slm-example-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            currentEjId = this.getAttribute('data-ejemploid');
            openExampleModal(currentEjId);
        });
    });

    function openExampleModal(ejId) {
        console.log('slm openModal ejId:', ejId);
        var data = document.querySelector('.slm-example-data[data-ejemploid="' + ejId + '"]');
        console.log('slm example-data found:', data);
        if (!data) { console.error('slm: no se encontró .slm-example-data para ejId=' + ejId); return; }

        var getText = function(f) {
            var el = data.querySelector('[data-field="' + f + '"]');
            return el ? el.textContent.trim() : '';
        };

        // Rellenar campos del modal.
        var setField = function(id, val) { var el = document.getElementById(id); if (el) { el.textContent = val; } };
        setField('slm-modal-titulo',      getText('titulo'));
        setField('slm-modal-descripcion', getText('descripcion'));
        setField('slm-modal-codigo',      getText('codigo'));
        setField('slm-modal-explicacion', getText('explicacion'));
        setField('slm-modal-resultado',   getText('resultado'));

        var hasCod = getText('has_codigo')    === '1';
        var hasRes = getText('has_resultado') === '1';
        var codWrap = document.getElementById('slm-modal-codigo-wrap');
        var resWrap = document.getElementById('slm-modal-resultado-wrap');
        if (codWrap) { codWrap.style.display = hasCod ? '' : 'none'; }
        if (resWrap) { resWrap.style.display = hasRes ? '' : 'none'; }

        // Modo edición en el modal: convertir divs en textareas.
        var saveBtn = document.getElementById('slm-modal-save-btn');
        if (editActive) {
            convertModalToEdit();
            if (saveBtn) { saveBtn.style.display = ''; }
        } else {
            restoreModalFromEdit();
            if (saveBtn) { saveBtn.style.display = 'none'; }
        }

        // Abrir modal via AMD (en Moodle, bootstrap no es global).
        var modalEl = document.getElementById('slm-example-modal');
        if (modalEl) {
            require(['theme_boost/bootstrap/modal'], function(Modal) {
                Modal.getOrCreateInstance(modalEl).show();
            });
        }
    }

    // Mapa campo display -> textarea para el modal.
    var MODAL_FIELDS = [
        { display: 'slm-modal-titulo',      taId: 'slm-ta-titulo' },
        { display: 'slm-modal-descripcion', taId: 'slm-ta-descripcion' },
        { display: 'slm-modal-codigo',      taId: 'slm-ta-codigo',      mono: true },
        { display: 'slm-modal-explicacion', taId: 'slm-ta-explicacion' },
        { display: 'slm-modal-resultado',   taId: 'slm-ta-resultado' },
    ];

    function convertModalToEdit() {
        MODAL_FIELDS.forEach(function(f) {
            var dispEl = document.getElementById(f.display);
            if (!dispEl) { return; }
            // Si ya hay un textarea, solo actualizar valor.
            var existing = document.getElementById(f.taId);
            if (existing) { existing.style.display = ''; dispEl.style.display = 'none'; return; }
            // Crear textarea.
            var ta = document.createElement('textarea');
            ta.id    = f.taId;
            ta.className = 'form-control form-control-sm mb-1';
            ta.rows  = 3;
            ta.value = dispEl.textContent.trim();
            if (f.mono) { ta.style.fontFamily = 'monospace'; ta.rows = 5; }
            ta.style.background  = '#fffde7';
            ta.style.borderColor = '#f9a825';
            dispEl.parentNode.insertBefore(ta, dispEl.nextSibling);
            dispEl.style.display = 'none';
        });
    }

    function restoreModalFromEdit() {
        MODAL_FIELDS.forEach(function(f) {
            var dispEl = document.getElementById(f.display);
            var ta     = document.getElementById(f.taId);
            if (dispEl) { dispEl.style.display = ''; }
            if (ta)     { ta.style.display = 'none'; }
        });
    }

    // ----- Guardar ejemplo desde modal -----------------------------------------------
    var modalSaveBtn = document.getElementById('slm-modal-save-btn');
    if (modalSaveBtn) {
        modalSaveBtn.addEventListener('click', function() {
            if (!currentEjId) { return; }
            var getTA = function(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; };
            var campos = {
                titulo:      getTA('slm-ta-titulo'),
                descripcion: getTA('slm-ta-descripcion'),
                codigo:      getTA('slm-ta-codigo'),
                explicacion: getTA('slm-ta-explicacion'),
                resultado:   getTA('slm-ta-resultado'),
            };

            modalSaveBtn.disabled = true;
            modalSaveBtn.innerHTML = '<i class="fa fa-spinner fa-spin fa-fw"></i> Guardando...';

            saveViaAjax('ejemplo', parseInt(currentEjId, 10), campos, function(ok) {
                modalSaveBtn.disabled = false;
                if (ok) {
                    // Actualizar datos ocultos y botón en la tabla.
                    var dataEl = document.querySelector('.slm-example-data[data-ejemploid="' + currentEjId + '"]');
                    if (dataEl) {
                        var fmap = {titulo:'titulo', descripcion:'descripcion',
                                    codigo:'codigo', explicacion:'explicacion', resultado:'resultado'};
                        Object.keys(fmap).forEach(function(f) {
                            var orig = dataEl.querySelector('[data-field="' + fmap[f] + '"]');
                            if (orig && campos[f] !== undefined) { orig.textContent = campos[f]; }
                        });
                        var listBtn = document.querySelector('.slm-example-btn[data-ejemploid="' + currentEjId + '"] .small');
                        if (listBtn && campos.titulo) { listBtn.textContent = campos.titulo; }
                    }
                    // Actualizar displays del modal.
                    MODAL_FIELDS.forEach(function(f) {
                        var dispEl = document.getElementById(f.display);
                        var ta     = document.getElementById(f.taId);
                        if (dispEl && ta) { dispEl.textContent = ta.value; }
                    });
                    modalSaveBtn.innerHTML = '<i class="fa fa-check fa-fw"></i> Guardado';
                    setTimeout(function() {
                        modalSaveBtn.innerHTML = '<i class="fa fa-save fa-fw"></i> Guardar ejemplo';
                    }, 2000);
                } else {
                    modalSaveBtn.innerHTML = '<i class="fa fa-times fa-fw"></i> Error — reintentar';
                    setTimeout(function() {
                        modalSaveBtn.innerHTML = '<i class="fa fa-save fa-fw"></i> Guardar ejemplo';
                    }, 2000);
                }
            });
        });
    }

})();
</script>

